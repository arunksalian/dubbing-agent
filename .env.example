# ============================================================
# AI Video Dubbing Agent - Environment Configuration
# ============================================================

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- S3 / MinIO Storage ---
S3_ENDPOINT_URL=http://localhost:9000         # Leave blank for AWS S3
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=dubbing-output
S3_REGION=us-east-1

# --- OpenAI (Translation) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- ElevenLabs (TTS) ---
ELEVENLABS_API_KEY=...

# --- Hugging Face (pyannote diarization model download) ---
HF_TOKEN=hf_...

# --- Whisper Model ---
WHISPER_MODEL_SIZE=medium         # tiny | base | small | medium | large-v3
WHISPER_DEVICE=cpu                # cpu | cuda
WHISPER_COMPUTE_TYPE=int8        # int8 | float16 | float32

# --- Application ---
UPLOAD_DIR=/tmp/dubbing/uploads
OUTPUT_DIR=/tmp/dubbing/outputs
MAX_UPLOAD_SIZE_MB=500
JOB_TTL_SECONDS=604800            # 7 days

# --- Logging ---
LOG_LEVEL=INFO
